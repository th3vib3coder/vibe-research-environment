{
  "name": "vibe-research-environment",
  "version": "0.1.0",
  "description": "Outer-project research shell for the Vibe Science kernel.",
  "private": true,
  "type": "module",
  "bin": {
    "vre": "bin/vre"
  },
  "scripts": {
    "check": "npm run validate && npm test",
    "test": "node --test",
    "validate": "node environment/tests/ci/run-all.js",
    "validate:closeout-honesty": "node environment/tests/ci/validate-closeout-honesty.js",
    "eval:save-phase1": "node environment/evals/save-phase1-artifacts.js",
    "eval:save-phase3": "node environment/evals/save-phase3-operator-validation-artifact.js",
    "eval:save-operator-validation": "node environment/evals/save-operator-validation-artifact.js",
    "eval:measure-context-baseline": "node environment/evals/measure-context-baseline.js"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "Apache-2.0"
}
