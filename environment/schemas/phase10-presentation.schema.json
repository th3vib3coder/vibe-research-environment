{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "phase10.presentation.v1",
  "title": "Phase 10 Presentation v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "presentationId",
    "domainId",
    "title",
    "sourcePageIds",
    "exportRecipeId",
    "stalenessPolicy",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "phase10.presentation.v1"
    },
    "presentationId": {
      "type": "string",
      "pattern": "^PRES-.+$"
    },
    "domainId": {
      "type": "string",
      "pattern": "^KDOM-.+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "sourcePageIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^WIKI-.+$"
      }
    },
    "exportRecipeId": {
      "type": "string",
      "pattern": "^EXPORT-.+$"
    },
    "stalenessPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxSourceAgeDays"],
      "properties": {
        "maxSourceAgeDays": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
