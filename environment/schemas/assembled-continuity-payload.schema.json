{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vibe-env/assembled-continuity-payload.schema.json",
  "title": "VRE Orchestrator Assembled Continuity Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "stableProfile",
    "dynamicContext",
    "retrievalHits",
    "sourceRefs",
    "warnings",
    "totalTokens",
    "truncated",
    "assembledAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "vibe-orch.assembled-continuity-payload.v1"
    },
    "stableProfile": {
      "type": "object"
    },
    "dynamicContext": {
      "type": "object"
    },
    "retrievalHits": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "hitId",
          "sourceType",
          "summary",
          "sourceRef",
          "isStale"
        ],
        "properties": {
          "hitId": {
            "type": "string",
            "minLength": 1
          },
          "sourceType": {
            "type": "string",
            "enum": [
              "memory-mirror",
              "decision-log",
              "attempt-summary",
              "experiment-bundle",
              "writing-pack",
              "export-alert",
              "lane-run"
            ]
          },
          "title": {
            "type": [
              "string",
              "null"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "sourceRef": {
            "type": "string",
            "minLength": 1
          },
          "recordedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "isStale": {
            "type": "boolean"
          }
        }
      }
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourceType",
          "label",
          "ref"
        ],
        "properties": {
          "sourceType": {
            "type": "string",
            "enum": [
              "memory-mirror",
              "decision-log",
              "attempt-summary",
              "experiment-bundle",
              "writing-pack",
              "export-alert",
              "lane-run"
            ]
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "recordedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "totalTokens": {
      "type": "integer",
      "minimum": 0
    },
    "truncated": {
      "type": "boolean"
    },
    "assembledAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
