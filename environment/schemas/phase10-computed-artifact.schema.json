{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "phase10.computed-artifact.v1",
  "title": "Phase 10 Computed Artifact v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactId",
    "domainId",
    "artifactType",
    "recipe",
    "provenanceLinks",
    "sensitivity",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "phase10.computed-artifact.v1"
    },
    "artifactId": {
      "type": "string",
      "pattern": "^ART-.+$"
    },
    "domainId": {
      "type": "string",
      "pattern": "^KDOM-.+$"
    },
    "artifactType": {
      "type": "string",
      "enum": ["table", "figure", "summary", "dataset", "metric"]
    },
    "recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "parameters"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "provenanceLinks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^PROV-.+$"
      }
    },
    "sensitivity": {
      "type": "string",
      "enum": ["public", "internal", "restricted"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
