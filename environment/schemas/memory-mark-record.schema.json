{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vibe-env/memory-mark-record.schema.json",
  "title": "VRE Memory Mark Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "targetType",
    "targetId",
    "mark"
  ],
  "properties": {
    "targetType": {
      "type": "string",
      "enum": [
        "claim",
        "experiment",
        "paper"
      ]
    },
    "targetId": {
      "type": "string",
      "minLength": 1
    },
    "mark": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{1,63}$"
    },
    "createdAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  }
}
