{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "phase9.objective.v1",
  "title": "Phase 9 Objective v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "objectiveId",
    "title",
    "question",
    "createdAt",
    "status",
    "budget",
    "runtimeMode",
    "reasoningMode",
    "wakePolicy",
    "stopConditions",
    "ownerAgentRole",
    "stages",
    "artifactsIndex",
    "createdBySession",
    "lastUpdatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "phase9.objective.v1"
    },
    "objectiveId": {
      "type": "string",
      "pattern": "^OBJ-.+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "blocked",
        "paused",
        "completed",
        "abandoned"
      ]
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "maxWallSeconds",
        "maxIterations",
        "maxTaskCount",
        "maxExternalCalls",
        "costCeiling",
        "heartbeatIntervalSeconds",
        "allowedTaskKinds",
        "networkPolicy",
        "humanApprovalRequiredForDestructive"
      ],
      "properties": {
        "schemaVersion": {
          "const": "phase9.runtime-budget.v1"
        },
        "maxWallSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "maxIterations": {
          "type": "integer",
          "minimum": 1
        },
        "maxTaskCount": {
          "type": "integer",
          "minimum": 1
        },
        "maxExternalCalls": {
          "type": "integer",
          "minimum": 0
        },
        "costCeiling": {
          "anyOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "heartbeatIntervalSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "allowedTaskKinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "networkPolicy": {
          "type": "string",
          "enum": [
            "off",
            "allowlist-only",
            "open"
          ]
        },
        "humanApprovalRequiredForDestructive": {
          "type": "boolean"
        }
      }
    },
    "runtimeMode": {
      "type": "string",
      "enum": [
        "interactive",
        "attended-batch",
        "unattended-batch",
        "resume-only"
      ]
    },
    "reasoningMode": {
      "type": "string",
      "enum": [
        "rule-only"
      ]
    },
    "wakePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "wakeOwner",
        "wakeSourceId",
        "leaseTtlSeconds",
        "duplicateWakePolicy"
      ],
      "properties": {
        "wakeOwner": {
          "type": "string",
          "enum": [
            "windows-task-scheduler",
            "codex-app",
            "vre-automation",
            "external-runner",
            "manual"
          ]
        },
        "wakeSourceId": {
          "type": [
            "string",
            "null"
          ]
        },
        "leaseTtlSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "duplicateWakePolicy": {
          "type": "string",
          "enum": [
            "no-op"
          ]
        }
      }
    },
    "stopConditions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "onBudgetExhausted",
        "onBlocker",
        "onAmbiguousEvidence",
        "onMissingInput",
        "onFailedGate",
        "onHumanDecisionNeeded"
      ],
      "properties": {
        "onBudgetExhausted": {
          "type": "string",
          "enum": [
            "block",
            "pause",
            "stop"
          ]
        },
        "onBlocker": {
          "type": "string",
          "enum": [
            "block"
          ]
        },
        "onAmbiguousEvidence": {
          "type": "string",
          "enum": [
            "block",
            "request-review"
          ]
        },
        "onMissingInput": {
          "type": "string",
          "enum": [
            "block"
          ]
        },
        "onFailedGate": {
          "type": "string",
          "enum": [
            "block"
          ]
        },
        "onHumanDecisionNeeded": {
          "type": "string",
          "enum": [
            "block"
          ]
        }
      }
    },
    "ownerAgentRole": {
      "type": "string",
      "minLength": 1
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stageId",
          "status"
        ],
        "properties": {
          "stageId": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "artifactsIndex": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "literature",
        "experiments",
        "results",
        "writing",
        "review"
      ],
      "properties": {
        "literature": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "experiments": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "results": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "writing": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "review": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "createdBySession": {
      "type": "string",
      "minLength": 1
    },
    "lastUpdatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
