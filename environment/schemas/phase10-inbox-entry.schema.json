{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "phase10.inbox-entry.v1",
  "title": "Phase 10 Inbox Entry v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "inboxEntryId",
    "domainId",
    "entryType",
    "sourceRef",
    "dedupeKeys",
    "discoveredBySkill",
    "discoveredByTask",
    "discoveredAt",
    "selectionRationale",
    "relevanceScore",
    "whyThisMatters",
    "candidateStatus",
    "priority",
    "payloadStatus",
    "createdAt"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "candidateStatus": {
            "const": "approved"
          }
        },
        "required": ["candidateStatus"]
      },
      "then": {
        "required": ["approval"]
      }
    },
    {
      "if": {
        "properties": {
          "candidateStatus": {
            "const": "rejected"
          }
        },
        "required": ["candidateStatus"]
      },
      "then": {
        "required": ["rejection"]
      }
    }
  ],
  "properties": {
    "schemaVersion": {
      "const": "phase10.inbox-entry.v1"
    },
    "inboxEntryId": {
      "type": "string",
      "pattern": "^INBOX-.+$"
    },
    "domainId": {
      "type": "string",
      "pattern": "^KDOM-.+$"
    },
    "entryType": {
      "type": "string",
      "enum": ["raw-document", "source-bundle", "wiki-page", "computed-artifact", "query-record"]
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["doi", "pmid", "arxiv", "url", "file", "operator-note", "other"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dedupeKeys": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "discoveredBySkill": {
      "type": "string",
      "minLength": 1
    },
    "discoveredByTask": {
      "type": "object",
      "additionalProperties": false,
      "required": ["objectiveId", "taskId"],
      "properties": {
        "objectiveId": {
          "type": "string",
          "minLength": 1
        },
        "taskId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "discoveredAt": {
      "type": "string",
      "format": "date-time"
    },
    "selectionRationale": {
      "type": "string",
      "minLength": 1
    },
    "relevanceScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "whyThisMatters": {
      "type": "string",
      "minLength": 1
    },
    "candidateStatus": {
      "type": "string",
      "enum": ["pending", "stale", "approved", "rejected", "deferred"]
    },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high", "urgent"]
    },
    "payloadStatus": {
      "type": "string",
      "enum": [
        "missing",
        "metadata-only",
        "abstract-only",
        "full-text-available",
        "preserved",
        "removed-copyright",
        "removed-sensitive"
      ]
    },
    "preliminaryMetadata": {
      "type": "object",
      "additionalProperties": true
    },
    "licenseGuess": {
      "type": "string",
      "enum": ["open", "user-owned", "permission-granted", "restricted", "unknown"]
    },
    "trustTierSuggestion": {
      "type": "string",
      "enum": ["primary", "secondary", "tertiary", "operator-provided"]
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approvedAt",
        "approvedBy",
        "license",
        "trustTier",
        "scopeOfUse",
        "promotedToBundle"
      ],
      "properties": {
        "approvedAt": {
          "type": "string",
          "format": "date-time"
        },
        "approvedBy": {
          "type": "string",
          "minLength": 1
        },
        "license": {
          "type": "string",
          "enum": ["open", "user-owned", "permission-granted", "restricted"]
        },
        "trustTier": {
          "type": "string",
          "enum": ["primary", "secondary", "tertiary", "operator-provided"]
        },
        "scopeOfUse": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "evidence",
              "background",
              "contradictory-evidence",
              "method-reference",
              "replication-evidence",
              "failed-replication"
            ]
          }
        },
        "promotedToBundle": {
          "type": "object",
          "additionalProperties": false,
          "required": ["bundleId", "bundleVersion"],
          "properties": {
            "bundleId": {
              "type": "string",
              "pattern": "^SB-.+$"
            },
            "bundleVersion": {
              "type": "string",
              "pattern": "^v[0-9][A-Za-z0-9._-]*$"
            }
          }
        }
      }
    },
    "rejection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rejectedAt", "rejectedBy", "rejectReason", "payloadStatus"],
      "properties": {
        "rejectedAt": {
          "type": "string",
          "format": "date-time"
        },
        "rejectedBy": {
          "type": "string",
          "minLength": 1
        },
        "rejectReason": {
          "type": "string",
          "minLength": 1
        },
        "payloadStatus": {
          "type": "string",
          "enum": ["preserved", "removed-copyright", "removed-sensitive"]
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
