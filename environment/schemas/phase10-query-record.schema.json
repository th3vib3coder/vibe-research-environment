{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "phase10.query-record.v1",
  "title": "Phase 10 Query Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "queryId",
    "domainId",
    "queryText",
    "issuedAt",
    "resultRefs",
    "decisionUse"
  ],
  "properties": {
    "schemaVersion": {
      "const": "phase10.query-record.v1"
    },
    "queryId": {
      "type": "string",
      "pattern": "^QUERY-.+$"
    },
    "domainId": {
      "type": "string",
      "pattern": "^KDOM-.+$"
    },
    "queryText": {
      "type": "string",
      "minLength": 1
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "resultRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decisionUse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "computedBy", "computedAt"],
      "properties": {
        "classification": {
          "type": "string",
          "minLength": 1
        },
        "computedBy": {
          "type": "string",
          "minLength": 1
        },
        "computedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
