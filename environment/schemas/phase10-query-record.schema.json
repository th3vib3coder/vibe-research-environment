{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "phase10.query-record.v1",
  "title": "Phase 10 Query Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "queryId",
    "domainId",
    "queryText",
    "issuedAt",
    "queryClass",
    "status",
    "outputPath",
    "outputBanner",
    "resultRefs",
    "decisionUse"
  ],
  "properties": {
    "schemaVersion": {
      "const": "phase10.query-record.v1"
    },
    "queryId": {
      "type": "string",
      "pattern": "^QUERY-.+$"
    },
    "domainId": {
      "type": "string",
      "pattern": "^KDOM-.+$"
    },
    "queryText": {
      "type": "string",
      "minLength": 1
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "queryClass": {
      "type": "string",
      "enum": [
        "lookup",
        "evidence-summary",
        "decision-support",
        "contradiction-audit",
        "report-generation"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["complete", "incomplete", "failed"]
    },
    "reportScope": {
      "type": "string",
      "enum": [
        "domain-summary",
        "recent-week",
        "inbox-status",
        "claim-status-overview",
        "single-objective"
      ]
    },
    "r2Audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1
        },
        "verdict": {
          "type": "string",
          "minLength": 1
        },
        "reviewer": {
          "type": "string",
          "minLength": 1
        },
        "reviewedAt": {
          "type": "string",
          "format": "date-time"
        },
        "accepted": {
          "type": "boolean"
        }
      }
    },
    "qualityGates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fullContradictionEnumeration": {
          "type": "boolean"
        },
        "contradictionEnumerationComplete": {
          "type": "boolean"
        }
      }
    },
    "outputPath": {
      "type": "string",
      "pattern": "^wiki/queries/QUERY-.+\\.md$"
    },
    "outputBanner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decisionUseClassification",
        "provenanceWarning"
      ],
      "properties": {
        "decisionUseClassification": {
          "type": "string",
          "minLength": 1
        },
        "provenanceWarning": {
          "const": "query-output-is-metadata-not-law13-provenance"
        }
      }
    },
    "resultRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decisionUse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "computedBy", "computedAt"],
      "properties": {
        "classification": {
          "type": "string",
          "enum": [
            "not-for-decision",
            "informational",
            "evidence-support",
            "decision-grade",
            "audit-grade"
          ]
        },
        "computedBy": {
          "const": "phase10-query-decision-use"
        },
        "computedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "queryClass": {
            "const": "report-generation"
          }
        },
        "required": ["queryClass"]
      },
      "then": {
        "required": ["reportScope"]
      }
    }
  ]
}
