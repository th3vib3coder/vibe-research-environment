{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vibe-env.operator-validation-artifact.v1",
  "title": "Operator Validation Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactId",
    "phase",
    "benchmarkId",
    "generatedAt",
    "createdAt",
    "passed",
    "replacesArtifact",
    "validationClaims",
    "decisions",
    "sourceRepeats",
    "evidence"
  ],
  "properties": {
    "schemaVersion": {
      "const": "vibe-env.operator-validation-artifact.v1"
    },
    "artifactId": {
      "type": "string",
      "pattern": "^phase[0-9]+-operator-validation$"
    },
    "phase": {
      "type": "integer",
      "minimum": 1
    },
    "benchmarkId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "passed": {
      "type": "boolean"
    },
    "replacesArtifact": {
      "type": ["string", "null"],
      "pattern": "^\\.vibe-science-environment/operator-validation/artifacts/archive/.+\\.json$"
    },
    "validationClaims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decisions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "sourceRepeats": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "$ref": "#/$defs/sourceRepeat"
        }
      }
    },
    "evidence": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/evidenceEntry"
      }
    }
  },
  "$defs": {
    "notApplicableMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason"],
      "properties": {
        "status": {
          "const": "not-applicable"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metricValue": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "$ref": "#/$defs/notApplicableMetric"
        }
      ]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/metricValue"
      },
      "minProperties": 1
    },
    "sourceRepeat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "taskId",
        "repeatId",
        "inputPath",
        "outputPath",
        "metricsPath",
        "summaryPath",
        "transcriptPath"
      ],
      "properties": {
        "taskId": {
          "type": "string",
          "minLength": 1
        },
        "repeatId": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}-\\d{2}$"
        },
        "inputPath": {
          "type": "string",
          "pattern": "^\\.vibe-science-environment/operator-validation/benchmarks/.+/input\\.json$"
        },
        "outputPath": {
          "type": "string",
          "pattern": "^\\.vibe-science-environment/operator-validation/benchmarks/.+/output\\.json$"
        },
        "metricsPath": {
          "type": "string",
          "pattern": "^\\.vibe-science-environment/operator-validation/benchmarks/.+/metrics\\.json$"
        },
        "summaryPath": {
          "type": "string",
          "pattern": "^\\.vibe-science-environment/operator-validation/benchmarks/.+/summary\\.json$"
        },
        "transcriptPath": {
          "type": "string",
          "pattern": "^\\.vibe-science-environment/operator-validation/benchmarks/.+/transcript\\.md$"
        }
      }
    },
    "evidenceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "sourceRepeat", "sourceRepeats", "metrics"],
      "properties": {
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "sourceRepeat": {
          "$ref": "#/$defs/sourceRepeat"
        },
        "sourceRepeats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceRepeat"
          }
        },
        "metrics": {
          "$ref": "#/$defs/metrics"
        }
      }
    }
  }
}
