{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "phase10.marp-template.v1",
  "title": "Phase 10 Marp Template v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "templateId",
    "domainId",
    "name",
    "theme",
    "allowedDirectives",
    "placeholders",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "phase10.marp-template.v1"
    },
    "templateId": {
      "type": "string",
      "pattern": "^MARP-.+$"
    },
    "domainId": {
      "type": "string",
      "pattern": "^KDOM-.+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "theme": {
      "type": "string",
      "minLength": 1
    },
    "allowedDirectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "placeholders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
