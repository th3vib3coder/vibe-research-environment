{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vibe-env/connector-run-record.schema.json",
  "title": "VRE Connector Run Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "connectorId",
    "runKind",
    "status",
    "startedAt",
    "endedAt",
    "sourceSurfaces",
    "target",
    "healthCheck",
    "visibleFailure",
    "warnings"
  ],
  "properties": {
    "schemaVersion": {
      "const": "vibe-env.connector-run-record.v1"
    },
    "runId": {
      "type": "string",
      "pattern": "^CONN-RUN-.+$"
    },
    "connectorId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "runKind": {
      "type": "string",
      "enum": [
        "export",
        "import",
        "health-check"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "degraded",
        "failed"
      ]
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "endedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "sourceSurfaces": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "external",
            "workspace"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "healthCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkedAt",
        "status",
        "details"
      ],
      "properties": {
        "checkedAt": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "degraded",
            "unavailable",
            "unknown"
          ]
        },
        "details": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "visibleFailure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surfacedInStatus",
        "failureKind",
        "message"
      ],
      "properties": {
        "surfacedInStatus": {
          "type": "boolean"
        },
        "failureKind": {
          "type": "string",
          "enum": [
            "none",
            "external-unavailable",
            "path-error",
            "contract-error",
            "unknown"
          ]
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
