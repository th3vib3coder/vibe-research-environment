{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "phase10.wiki-page.v1",
  "title": "Phase 10 Wiki Page v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "pageId",
    "domainId",
    "type",
    "title",
    "path",
    "compilePolicyId",
    "assertionGraph",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "phase10.wiki-page.v1"
    },
    "pageId": {
      "type": "string",
      "pattern": "^WIKI-.+$"
    },
    "domainId": {
      "type": "string",
      "pattern": "^KDOM-.+$"
    },
    "type": {
      "type": "string",
      "enum": ["source", "concept", "synthesis", "hypothesis", "entity"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "compilePolicyId": {
      "type": "string",
      "pattern": "^CP-.+$"
    },
    "lifecycleStatus": {
      "type": "string",
      "enum": ["draft", "active", "superseded", "retracted"]
    },
    "nexusStatus": {
      "type": "string",
      "const": "not-established"
    },
    "r2Audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "verdict",
        "reviewer",
        "reviewedAt",
        "law13ReviewExtension"
      ],
      "properties": {
        "status": {
          "type": "string",
          "const": "passed"
        },
        "verdict": {
          "type": "string",
          "const": "ACCEPT"
        },
        "reviewer": {
          "type": "string",
          "minLength": 1
        },
        "reviewedAt": {
          "type": "string",
          "format": "date-time"
        },
        "law13ReviewExtension": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "law13StatusChecked",
            "provenanceRefsChecked",
            "queryNotProvenanceCheck",
            "r2PathRequired",
            "r2PathPresent",
            "suppositionIsolationChecked"
          ],
          "properties": {
            "law13StatusChecked": {
              "type": "boolean"
            },
            "provenanceRefsChecked": {
              "type": "boolean"
            },
            "queryNotProvenanceCheck": {
              "type": "boolean"
            },
            "r2PathRequired": {
              "type": "boolean"
            },
            "r2PathPresent": {
              "type": "boolean"
            },
            "suppositionIsolationChecked": {
              "type": "boolean"
            }
          }
        },
        "repairAttempts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["rejectionEventId", "rejectedStatementIds", "action"],
            "properties": {
              "rejectionEventId": {
                "type": "string",
                "minLength": 1
              },
              "rejectedStatementIds": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "pattern": "^ASSERT-.+$"
                }
              },
              "action": {
                "type": "string",
                "const": "metadata-only-retry"
              }
            }
          }
        }
      }
    },
    "assertionGraph": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["assertionId", "text", "status", "cites"],
        "properties": {
          "assertionId": {
            "type": "string",
            "pattern": "^ASSERT-.+$"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["sourced", "computed", "claimed", "supposition"]
          },
          "cites": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^PROV-.+$"
            }
          }
        }
      }
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "hypothesis"
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["nexusStatus"]
      }
    }
    ,
    {
      "if": {
        "properties": {
          "type": {
            "const": "synthesis"
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["r2Audit"]
      }
    }
  ]
}
