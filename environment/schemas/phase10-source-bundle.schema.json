{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "phase10.source-bundle.v1",
  "title": "Phase 10 Source Bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bundleId",
    "bundleVersion",
    "domainId",
    "title",
    "sourceType",
    "trustTier",
    "license",
    "allowTrackPayload",
    "scopeOfUse",
    "rawDocumentRefs",
    "sourceLocators",
    "collectedAt",
    "status"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "curated"
          }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["license", "scopeOfUse"],
        "properties": {
          "license": {
            "not": {
              "const": "unknown"
            }
          },
          "scopeOfUse": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "properties": {
    "schemaVersion": {
      "const": "phase10.source-bundle.v1"
    },
    "bundleId": {
      "type": "string",
      "pattern": "^SB-.+$"
    },
    "bundleVersion": {
      "type": "string",
      "pattern": "^v[0-9][A-Za-z0-9._-]*$"
    },
    "domainId": {
      "type": "string",
      "pattern": "^KDOM-.+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "sourceType": {
      "type": "string",
      "enum": ["pdf", "webpage", "dataset", "markdown", "note", "other"]
    },
    "trustTier": {
      "type": "string",
      "enum": ["primary", "secondary", "tertiary", "operator-provided"]
    },
    "license": {
      "type": "string",
      "enum": ["open", "user-owned", "permission-granted", "restricted", "unknown"],
      "default": "unknown"
    },
    "allowTrackPayload": {
      "type": "boolean",
      "default": false
    },
    "scopeOfUse": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "evidence",
          "background",
          "contradictory-evidence",
          "method-reference",
          "replication-evidence",
          "failed-replication"
        ]
      }
    },
    "rawDocumentRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rawDocumentId"],
        "properties": {
          "rawDocumentId": {
            "type": "string",
            "pattern": "^RAW-.+$"
          },
          "contentHash": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "sourceLocators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "uri"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["file", "url", "doi", "obsidian"]
          },
          "uri": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "collectedAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["raw", "curated", "rejected", "archived"]
    }
  }
}
