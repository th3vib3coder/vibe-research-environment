{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vibe-env/task-registry-entry.schema.json",
  "title": "VRE Orchestrator Task Registry Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "taskKind",
    "lane",
    "requiredCapability",
    "helperModule",
    "helperExport",
    "inputSchema",
    "outputContract",
    "routerKeywords",
    "degradesTo"
  ],
  "properties": {
    "schemaVersion": {
      "const": "vibe-env.task-registry-entry.v1"
    },
    "taskKind": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "minLength": 3
    },
    "lane": {
      "type": "string",
      "enum": [
        "execution",
        "review"
      ]
    },
    "requiredCapability": {
      "type": "string",
      "enum": [
        "output-only",
        "programmatic",
        "interactive"
      ]
    },
    "helperModule": {
      "type": "string",
      "pattern": "^environment/[A-Za-z0-9_./-]+\\.js$"
    },
    "helperExport": {
      "type": "string",
      "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*$"
    },
    "inputSchema": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^environment/schemas/[A-Za-z0-9._-]+\\.schema\\.json$"
    },
    "outputContract": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "summary",
        "artifactRefs",
        "warningCount"
      ],
      "description": "Documentation of the expected lane-run-record payload shape for this task kind. Values are descriptive type hints (e.g., 'integer', arrays of placeholder path names); they are not asserted at runtime."
    },
    "routerKeywords": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "degradesTo": {
      "type": "string",
      "pattern": "^(escalate|noop|[a-z][a-z0-9-]*)$"
    }
  }
}
