{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vibe-env/domain-pack.schema.json",
  "title": "VRE Domain Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packId",
    "displayName",
    "authorityBoundary",
    "domainAssumptions",
    "supportedWorkflows",
    "literatureSources",
    "experimentPresets",
    "deliverableTemplates",
    "advisoryHints",
    "doesNotModify"
  ],
  "properties": {
    "schemaVersion": {
      "const": "vibe-env.domain-pack.v1"
    },
    "packId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "authorityBoundary": {
      "const": "presets-only"
    },
    "domainAssumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supportedWorkflows": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "literatureSources": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "experimentPresets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultFields",
        "commonConfounders"
      ],
      "properties": {
        "defaultFields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "commonConfounders": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "deliverableTemplates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expectedConnectors": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      }
    },
    "advisoryHints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "doesNotModify": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
