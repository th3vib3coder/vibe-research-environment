{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vibe-env/external-review-record.schema.json",
  "title": "VRE Orchestrator External Review Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "externalReviewId",
    "taskId",
    "executionLaneRunId",
    "reviewLaneRunId",
    "verdict",
    "materialMismatch",
    "comparedArtifactRefs",
    "followUpAction",
    "recordedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "vibe-orch.external-review-record.v1"
    },
    "externalReviewId": {
      "type": "string",
      "pattern": "^ORCH-REVIEW-.+$"
    },
    "taskId": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^ORCH-TASK-.+$"
    },
    "executionLaneRunId": {
      "type": "string",
      "pattern": "^ORCH-RUN-.+$"
    },
    "reviewLaneRunId": {
      "type": "string",
      "pattern": "^ORCH-RUN-.+$"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "affirmed",
        "challenged",
        "inconclusive"
      ]
    },
    "materialMismatch": {
      "type": "boolean"
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "comparedArtifactRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "followUpAction": {
      "type": "string",
      "enum": [
        "none",
        "reroute",
        "escalate",
        "revise",
        "accept-with-warning"
      ]
    },
    "escalationId": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^ORCH-ESC-.+$"
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
