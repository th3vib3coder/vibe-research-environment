{
  "taskId": "weekly-digest-reviewable-artifact",
  "version": "1.0.0",
  "phase": 4,
  "benchmarkIds": ["phase4-external-surfaces"],
  "command": {
    "name": "/weekly-digest",
    "scope": "weekly-digest",
    "args": []
  },
  "goal": "Generate one reviewable weekly digest artifact and keep the run ledger visible without mutating kernel truth.",
  "setup": {
    "workspaceFixtures": [
      {
        "path": ".vibe-science-environment/.install-state.json",
        "kind": "install-state",
        "state": "present"
      },
      {
        "path": ".vibe-science-environment/control/session.json",
        "kind": "session-snapshot",
        "state": "present"
      }
    ],
    "kernelReader": {
      "dbAvailable": false,
      "error": "bridge unavailable"
    }
  },
  "expected": {
    "attemptStatus": "succeeded",
    "requiredWrites": [
      ".vibe-science-environment/control/attempts.jsonl",
      ".vibe-science-environment/control/capabilities.json",
      ".vibe-science-environment/control/events.jsonl",
      ".vibe-science-environment/control/session.json",
      ".vibe-science-environment/automation/artifacts/weekly-research-digest/2026-W14.md",
      ".vibe-science-environment/automation/runs/weekly-research-digest.jsonl"
    ],
    "forbiddenPathPrefixes": [
      ".vibe-science/",
      "CLAIM-LEDGER.md"
    ]
  },
  "metrics": [
    "resume-latency",
    "honesty-under-degradation",
    "state-write-scope",
    "attempt-lifecycle-completeness",
    "snapshot-publish-success"
  ],
  "sourceTests": [
    "environment/tests/lib/automation.test.js",
    "environment/tests/integration/automation-runtime.test.js"
  ]
}
