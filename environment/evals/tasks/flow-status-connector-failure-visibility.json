{
  "taskId": "flow-status-connector-failure-visibility",
  "version": "1.0.0",
  "phase": 4,
  "benchmarkIds": ["phase4-external-surfaces"],
  "command": {
    "name": "/flow-status",
    "scope": "flow-status",
    "args": []
  },
  "goal": "Surface a previously recorded connector export failure through /flow-status without inventing recovery or hiding the failed run.",
  "setup": {
    "workspaceFixtures": [
      {
        "path": ".vibe-science-environment/.install-state.json",
        "kind": "install-state",
        "state": "present"
      },
      {
        "path": ".vibe-science-environment/connectors/filesystem-export/run-log.jsonl",
        "kind": "connector-run-log",
        "state": "present"
      },
      {
        "path": ".vibe-science-environment/connectors/filesystem-export/status.json",
        "kind": "connector-status",
        "state": "present"
      }
    ],
    "kernelReader": {
      "dbAvailable": false,
      "error": "bridge unavailable"
    }
  },
  "expected": {
    "attemptStatus": "succeeded",
    "snapshotAssertions": {
      "activeFlow": null,
      "lastCommand": "/flow-status",
      "kernel": {
        "dbAvailable": false,
        "degradedReason": "bridge unavailable"
      }
    },
    "resultAssertions": {
      "connectors": {
        "runtimeInstalled": true,
        "totalConnectors": 2
      }
    },
    "requiredWrites": [
      ".vibe-science-environment/control/attempts.jsonl",
      ".vibe-science-environment/control/capabilities.json",
      ".vibe-science-environment/control/events.jsonl",
      ".vibe-science-environment/control/session.json"
    ],
    "forbiddenPathPrefixes": [
      ".vibe-science/",
      "CLAIM-LEDGER.md"
    ]
  },
  "metrics": [
    "resume-latency",
    "honesty-under-degradation",
    "state-write-scope",
    "attempt-lifecycle-completeness",
    "snapshot-publish-success"
  ],
  "sourceTests": [
    "environment/tests/lib/connectors.test.js",
    "environment/tests/control/query.test.js"
  ]
}
