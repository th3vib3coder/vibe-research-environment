{
  "taskId": "orchestrator-continuity-modes",
  "version": "1.0.0",
  "phase": 5,
  "benchmarkIds": ["phase5-orchestrator-mvp"],
  "command": {
    "name": "/orchestrator-status",
    "scope": "orchestrator-status",
    "args": []
  },
  "goal": "Prove that the continuity assembler produces usable profile, query, and full modes without auto-capture, and that query/full recall is helper-backed.",
  "setup": {
    "workspaceFixtures": [],
    "kernelReader": {
      "dbAvailable": false,
      "error": "bridge unavailable"
    }
  },
  "expected": {
    "attemptStatus": "succeeded",
    "snapshotAssertions": {
