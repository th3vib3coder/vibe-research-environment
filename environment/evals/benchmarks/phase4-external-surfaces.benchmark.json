{
  "benchmarkId": "phase4-external-surfaces",
  "version": "1.0.0",
  "phase": 4,
  "description": "Phase 4 operator-trust benchmark for connector honesty, reviewable automation artifacts, and domain-pack preset surfacing.",
  "taskIds": [
    "flow-status-connector-failure-visibility",
    "weekly-digest-reviewable-artifact",
    "stale-memory-reminder-reviewable-artifact",
    "export-warning-digest-reviewable-artifact",
    "flow-status-domain-pack-omics",
    "flow-status-domain-pack-fallback"
  ],
  "metricIds": [
    "resume-latency",
    "honesty-under-degradation",
    "state-write-scope",
    "attempt-lifecycle-completeness",
    "snapshot-publish-success"
  ],
  "repeatPolicy": {
    "defaultRepeats": 1,
    "preserveAllRepeats": true,
    "overwriteExistingRepeats": false
  },
  "passCriteria": {
    "requiredTaskIds": [
      "flow-status-connector-failure-visibility",
      "weekly-digest-reviewable-artifact",
      "stale-memory-reminder-reviewable-artifact",
      "export-warning-digest-reviewable-artifact",
      "flow-status-domain-pack-omics",
      "flow-status-domain-pack-fallback"
    ],
    "forbidKernelWriteViolations": true,
    "requireVisibleConnectorFailure": true,
    "requireReviewableAutomationArtifacts": true,
    "requireDomainPackActivation": true,
    "requireDefaultDomainFallback": true
  }
}
