  "metricIds": [
    "resume-latency",
    "honesty-under-degradation",
    "state-write-scope",
    "attempt-lifecycle-completeness",
    "snapshot-publish-success"
  ],
  "repeatPolicy": {
    "defaultRepeats": 1,
    "preserveAllRepeats": true,
    "overwriteExistingRepeats": false
  },
  "passCriteria": {
    "requiredTaskIds": [
      "orchestrator-status-queue-resume",
      "orchestrator-continuity-modes",
      "orchestrator-execution-review-lineage",
      "orchestrator-bounded-failure-recovery"
    ],
    "forbidKernelWriteViolations": true,
