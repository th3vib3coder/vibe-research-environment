const SESSION_SNAPSHOT_PATH = '.vibe-science-environment/control/session.json';
const PHASE9_ROOTS = [...new Set(PHASE9_STUB_DEFINITIONS.map((definition) => definition.root))].sort();
const KNOWN_COMMANDS = [
  ...Object.keys(DISPATCH_TABLE).filter((commandName) => !commandName.includes(' ')),
  ...PHASE9_ROOTS,
  'init'
].sort();
const PHASE9_LOOKUP = new Map(
  PHASE9_STUB_DEFINITIONS.map((definition) => [`${definition.root}::${definition.action ?? ''}`, definition])
);

// Sibling kernel auto-discovery: if VRE_KERNEL_PATH is not set, look for a
// common layout where vibe-science lives beside vibe-research-environment in
// the same parent directory. Keeps the env var as the authoritative override.
function autoDiscoverSiblingKernel(repoRoot) {
  const parent = path.dirname(repoRoot);
  const candidates = [
    path.join(parent, 'vibe-science'),
    path.join(parent, 'vibe-science-plugin'),
  ];
  for (const candidate of candidates) {
    const cli = path.join(candidate, 'plugin', 'scripts', 'core-reader-cli.js');
    if (existsSync(cli)) {
      return candidate;
    }
  }
  return null;
}

export function resolveKernelRoot(repoRoot) {
  const explicit = process.env.VRE_KERNEL_PATH;
  if (typeof explicit === 'string' && explicit.trim() !== '') {
    return { kernelRoot: explicit, source: 'env' };
  }
  const discovered = autoDiscoverSiblingKernel(repoRoot);
  if (discovered) {
    return { kernelRoot: discovered, source: 'sibling-auto-discovery' };
  }
  return { kernelRoot: null, source: 'not-found' };
}

function isDirectRun(importMeta) {
  return process.argv[1] != null && importMeta.url === pathToFileURL(process.argv[1]).href;
}

function normalizeSlashes(value) {
  return value.split(path.sep).join('/');
}

function findPhase9Definition(root, action = null) {
  return PHASE9_LOOKUP.get(`${root}::${action ?? ''}`) ?? null;
}

function readPackageName(candidateRoot) {
  try {
    const packagePath = path.join(candidateRoot, 'package.json');
    return JSON.parse(readFileSync(packagePath, 'utf8')).name ?? null;
  } catch {
    return null;
  }
}

export function resolveRepoRoot(startCwd = process.cwd()) {
  let current = path.resolve(startCwd);

  while (true) {
    if (
      readPackageName(current) === 'vibe-research-environment' &&
      existsSync(path.join(current, 'environment', 'schemas'))
    ) {
      return current;
    }

    const parent = path.dirname(current);
    if (parent === current) {
      return null;
    }
    current = parent;
  }
}

export function parseCommandFrontmatter(markdown) {
  const normalized = markdown.replace(/\r\n/gu, '\n');
  const match = /^---\n([\s\S]*?)\n---\n/u.exec(normalized);
  if (!match) {
    return {};
  }

  const result = {};
  let section = result;
  for (const rawLine of match[1].split('\n')) {
    if (rawLine.trim() === '') {
      continue;
    }

    const sectionMatch = /^([a-zA-Z0-9_-]+):\s*$/u.exec(rawLine);
    if (sectionMatch) {
      result[sectionMatch[1]] = {};
      section = result[sectionMatch[1]];
      continue;
    }

    const pairMatch = /^\s*([a-zA-Z0-9_-]+):\s*(.*)$/u.exec(rawLine);
    if (!pairMatch) {
      throw new Error(`Unsupported frontmatter line: ${rawLine}`);
    }

    const [, key, rawValue] = pairMatch;
    const value = rawValue === 'true'
      ? true
      : rawValue === 'false'
        ? false
        : rawValue;
    section[key] = value;
  }

  return result;
}

async function callCoreReaderCli(cliPath, command, input = {}) {
  return new Promise((resolve, reject) => {
    const child = spawn(process.execPath, [cliPath, command], {
      stdio: ['pipe', 'pipe', 'pipe']
    });
    let stdout = '';
    let stderr = '';
    child.stdout.on('data', (chunk) => {
      stdout += chunk;
    });
    child.stderr.on('data', (chunk) => {
      stderr += chunk;
    });
    child.on('error', reject);
    child.on('close', (code) => {
      if (code !== 0) {
        reject(new Error(stderr.trim() || `core-reader CLI exited ${code}`));
        return;
      }
      try {
        resolve(stdout.trim() === '' ? null : JSON.parse(stdout));
      } catch (error) {
        reject(new Error(`core-reader CLI returned invalid JSON: ${error.message}`));
      }
    });
    child.stdin.end(`${JSON.stringify(input)}\n`);
  });
}

export async function resolveDefaultReader(repoRoot, { announce = false } = {}) {
  // WP-166 (Phase 6 Wave 3): delegate to the unified kernel-bridge helper.
  // The bridge handles VRE_KERNEL_PATH detection, degraded sentinel shape,
  // envelope validation, typed error taxonomy, and env sanitization — all
  // centrally.
  //
  // Dogfood pass 2026-04-18: accept a repoRoot-relative sibling auto-discovery
  // so a fresh checkout with `vibe-science/` parallel to `vibe-research-environment/`
  // works without the user having to set VRE_KERNEL_PATH explicitly.
  const { kernelRoot, source } = resolveKernelRoot(repoRoot);
  const reader = await resolveKernelReader({ kernelRoot });
  if (announce) {
    if (reader.dbAvailable) {
      process.stderr.write(
        `vre: kernel-bridge active (${source}: ${kernelRoot})\n`,
      );
    } else {
      const hint = source === 'env'
        ? `VRE_KERNEL_PATH="${kernelRoot}" points at a missing or unreadable kernel`
        : 'set VRE_KERNEL_PATH=<path-to-vibe-science-checkout> to enable kernel-backed projections';
      process.stderr.write(
        `vre: kernel-bridge degraded (${reader.error ?? 'unknown'}); ${hint}\n`,
      );
    }
  }
  return reader;
}

function budgetFromEnv() {
  const maxUsd = Number(process.env.VRE_BUDGET_MAX_USD);
  const estimatedCostUsd = Number(process.env.VRE_BUDGET_ESTIMATED_COST_USD);
  if (!Number.isFinite(maxUsd) && !Number.isFinite(estimatedCostUsd)) {
    return {};
  }
  return {
    ...(Number.isFinite(maxUsd) ? { maxUsd } : {}),
    ...(Number.isFinite(estimatedCostUsd) ? { estimatedCostUsd } : {})
  };
}

function summaryLine(subcommand, attempt, result, durationMs) {
  const fields = [
    subcommand,
    attempt?.attemptId ?? 'ATT-unknown',
    normalizeSlashes(SESSION_SNAPSHOT_PATH),
    String(durationMs)
  ];

  const activeObjective = result?.result?.payload?.activeObjective
    ?? result?.payload?.activeObjective
    ?? null;
  if (subcommand === 'orchestrator-status') {
    fields.push(`objective=${activeObjective ?? 'none'}`);
  }

  return fields.join('\t');
}

function printUsage(stderr = process.stderr) {
  stderr.write(`vre: usage: node bin/vre <${KNOWN_COMMANDS.join('|')}>\n`);
}

function printUnknown(subcommand) {
  process.stderr.write(`vre: unknown subcommand "${subcommand}". Allowed: ${KNOWN_COMMANDS.join(', ')}\n`);
}

function parseLongOptions(tokens) {
  const options = {};
  const positionals = [];

  for (let index = 0; index < tokens.length; index += 1) {
    const token = tokens[index];
    if (token === '--') {
      positionals.push(...tokens.slice(index + 1));
      break;
    }

    if (!token.startsWith('--') || token === '--') {
      positionals.push(token);
      continue;
    }

    const body = token.slice(2);
    if (body.includes('=')) {
      const [key, ...rawRest] = body.split('=');
      options[key] = rawRest.join('=');
      continue;
    }

    const next = tokens[index + 1];
    if (next && !next.startsWith('--')) {
      options[body] = next;
      index += 1;
      continue;
    }

    options[body] = true;
  }

  return { options, positionals };
}

function phase9SuccessPayload(command, extra = {}) {
  return {
    ok: true,
    command,
    phase9: true,
    ...extra
  };
}

function namedPhase9ErrorPayload(command, code, message, extra = {}) {
  return {
    ok: false,
    command,
    code,
    phase9: true,
    message,
    ...extra
  };
}

function resolvePhase9SessionId() {
  const explicit = process.env.VRE_SESSION_ID;
  if (typeof explicit === 'string' && explicit.trim() !== '') {
    return explicit.trim();
  }

  return `sess-cli-${process.pid}`;
}

function requiredStringOption(parsed, optionName, commandName) {
  const value = parsed.options[optionName];
  if (typeof value !== 'string' || value.trim() === '') {
    throw new Error(`${commandName} requires --${optionName}`);
  }
  return value.trim();
}

function parseInlineScalar(rawValue) {
  const trimmed = String(rawValue).trim();
  if (trimmed === 'true') {
    return true;
  }
  if (trimmed === 'false') {
    return false;
  }
  if (trimmed === 'null') {
    return null;
  }
  if (/^-?\d+$/u.test(trimmed)) {
    return Number.parseInt(trimmed, 10);
  }
  if (/^-?\d+\.\d+$/u.test(trimmed)) {
    return Number.parseFloat(trimmed);
  }
  if (trimmed.includes('|')) {
    return trimmed.split('|').map((value) => value.trim()).filter(Boolean);
  }
  return trimmed;
}

function parseInlineObject(rawValue, label) {
  const pairs = String(rawValue)
    .split(',')
    .map((value) => value.trim())
    .filter(Boolean);

  if (pairs.length === 0) {
    throw new Error(`${label} must not be empty`);
  }

  const result = {};
  for (const pair of pairs) {
    const separatorIndex = pair.indexOf('=');
    if (separatorIndex <= 0) {
      throw new Error(`${label} entries must use key=value: ${pair}`);
    }

    const key = pair.slice(0, separatorIndex).trim();
    const value = pair.slice(separatorIndex + 1);
    result[key] = parseInlineScalar(value);
  }

  return result;
}

async function loadInlineOrJsonObject(projectRoot, rawValue, label) {
  if (typeof rawValue !== 'string' || rawValue.trim() === '') {
    throw new Error(`${label} is required`);
  }

  const trimmed = rawValue.trim();
  const candidatePath = path.resolve(projectRoot, trimmed);
  if (
    existsSync(candidatePath) &&
    !trimmed.includes('=') &&
    !trimmed.startsWith('{') &&
    !trimmed.startsWith('[')
  ) {
    return JSON.parse(await readFile(candidatePath, 'utf8'));
  }

  if (trimmed.startsWith('{') || trimmed.startsWith('[')) {
    return JSON.parse(trimmed);
  }

  return parseInlineObject(trimmed, label);
}

function coercePositiveInteger(value, label) {
  if (!Number.isInteger(value) || value < 1) {
    throw new Error(`${label} must be a positive integer`);
  }
  return value;
}

function coerceNonNegativeInteger(value, label) {
  if (!Number.isInteger(value) || value < 0) {
    throw new Error(`${label} must be a non-negative integer`);
  }
  return value;
}

function coerceNullableNumber(value, label) {
  if (value === null) {
    return null;
  }
  if (typeof value !== 'number' || Number.isNaN(value) || value < 0) {
    throw new Error(`${label} must be a non-negative number or null`);
  }
  return value;
}

function normalizeAllowedTaskKinds(value, fallback) {
  if (value == null) {
    return [...fallback];
  }
  if (Array.isArray(value)) {
    return value.map((entry) => String(entry).trim()).filter(Boolean);
  }
  if (typeof value === 'string' && value.trim() !== '') {
    return value.split('|').map((entry) => entry.trim()).filter(Boolean);
  }
  throw new Error('budget.allowedTaskKinds must be an array or pipe-delimited string');
}

async function buildObjectiveBudget(projectRoot, rawBudget) {
  const registry = await getTaskRegistry();
  const defaultTaskKinds = [...registry.keys()].sort();
  const maxIterations = coercePositiveInteger(rawBudget.maxIterations, 'budget.maxIterations');
  return {
    schemaVersion: 'phase9.runtime-budget.v1',
    maxWallSeconds: coercePositiveInteger(rawBudget.maxWallSeconds, 'budget.maxWallSeconds'),
    maxIterations,
    maxTaskCount: coercePositiveInteger(
      rawBudget.maxTaskCount ?? maxIterations * 2,
      'budget.maxTaskCount'
    ),
    maxExternalCalls: coerceNonNegativeInteger(
      rawBudget.maxExternalCalls ?? DEFAULT_MAX_EXTERNAL_CALLS,
      'budget.maxExternalCalls'
    ),
    costCeiling: coerceNullableNumber(
      rawBudget.costCeiling ?? null,
      'budget.costCeiling'
    ),
    heartbeatIntervalSeconds: coercePositiveInteger(
      rawBudget.heartbeatIntervalSeconds,
      'budget.heartbeatIntervalSeconds'
    ),
    allowedTaskKinds: normalizeAllowedTaskKinds(
      rawBudget.allowedTaskKinds,
      defaultTaskKinds
    ),
    networkPolicy: rawBudget.networkPolicy ?? 'allowlist-only',
    humanApprovalRequiredForDestructive:
      rawBudget.humanApprovalRequiredForDestructive ?? true
  };
}

function buildObjectiveWakePolicy(rawWakePolicy, runtimeMode, budget) {
  if (rawWakePolicy == null) {
    if (runtimeMode === 'interactive') {
      return {
        wakeOwner: 'manual',
        wakeSourceId: null,
        leaseTtlSeconds: budget.heartbeatIntervalSeconds,
        duplicateWakePolicy: 'no-op'
      };
    }
    throw new Error('objective start requires --wake-policy for non-interactive modes');
  }

  const wakeOwner = rawWakePolicy.wakeOwner;
  if (typeof wakeOwner !== 'string' || wakeOwner.trim() === '') {
    throw new Error('wakePolicy.wakeOwner is required');
  }

  return {
    wakeOwner,
    wakeSourceId: rawWakePolicy.wakeSourceId ?? null,
    leaseTtlSeconds: coercePositiveInteger(
      rawWakePolicy.leaseTtlSeconds ?? budget.heartbeatIntervalSeconds,
      'wakePolicy.leaseTtlSeconds'
    ),
    duplicateWakePolicy: rawWakePolicy.duplicateWakePolicy ?? 'no-op'
  };
}

function buildInitialObjectiveRecord({ title, question, runtimeMode, reasoningMode, budget, wakePolicy, sessionId }) {
  const timestamp = now();
  return {
    schemaVersion: 'phase9.objective.v1',
    title,
    question,
    createdAt: timestamp,
    status: 'active',
    budget,
    runtimeMode,
    reasoningMode,
    wakePolicy,
    stopConditions: {
      onBudgetExhausted: 'block',
      onBlocker: 'block',
      onAmbiguousEvidence: 'request-review',
      onMissingInput: 'block',
      onFailedGate: 'block',
      onHumanDecisionNeeded: 'block'
    },
    ownerAgentRole: DEFAULT_OBJECTIVE_OWNER_ROLE,
    stages: [
      {
        stageId: 'orientation',
        status: 'active'
      }
    ],
    artifactsIndex: {
      literature: [],
      experiments: [],
      results: [],
      writing: [],
      review: []
    },
    createdBySession: sessionId,
    lastUpdatedAt: timestamp
  };
}

async function persistCapabilityHandshakeArtifact(repoRoot) {
  const handshake = await generateCapabilityHandshake(repoRoot, {
    cliMetadata: {
      DISPATCH_TABLE,
      IMPLEMENTED_PHASE9_COMMANDS,
      PHASE9_STUB_DEFINITIONS,
      resolveKernelRoot
    }
  });
  const artifactPath = resolveInside(repoRoot, HANDSHAKE_ARTIFACT_PATH);
  await atomicWriteJson(artifactPath, handshake);
  return {
    artifactPath,
    handshake
  };
}

function objectiveLockHeldPayload(error) {
  return namedPhase9ErrorPayload(
    'objective start',
    'OBJECTIVE_LOCK_HELD',
    error.message,
    {
      activeObjectiveId: error.objectiveId,
      activePointer: error.pointerPath,
      stopCommand: error.stopCommand,
      pauseCommand: error.pauseCommand
    }
  );
}

async function runObjectiveStart(repoRoot, parsed) {
  const title = requiredStringOption(parsed, 'title', 'objective start');
  const question = requiredStringOption(parsed, 'question', 'objective start');
  const runtimeMode = requiredStringOption(parsed, 'mode', 'objective start');
  const reasoningMode = parsed.options['reasoning-mode'] ?? 'rule-only';
  const rawBudget = await loadInlineOrJsonObject(repoRoot, parsed.options.budget, '--budget');
  const budget = await buildObjectiveBudget(repoRoot, rawBudget);
  const rawWakePolicy = parsed.options['wake-policy'] == null
    ? null
    : await loadInlineOrJsonObject(repoRoot, parsed.options['wake-policy'], '--wake-policy');
  const wakePolicy = buildObjectiveWakePolicy(rawWakePolicy, runtimeMode, budget);
  const sessionId = resolvePhase9SessionId();
  const objectiveRecord = buildInitialObjectiveRecord({
    title,
    question,
    runtimeMode,
    reasoningMode,
    budget,
    wakePolicy,
    sessionId
  });

  const activation = await activateObjective(repoRoot, objectiveRecord, {
    lockAcquiredBySession: sessionId
  });
  let persistedHandshake;
  try {
    persistedHandshake = await persistCapabilityHandshakeArtifact(repoRoot);
  } catch (error) {
    await deleteActiveObjectivePointer(
      repoRoot,
      activation.objectiveRecord.objectiveId
    ).catch(() => {});
    await deleteObjectiveStore(
      repoRoot,
      activation.objectiveRecord.objectiveId
    ).catch(() => {});
    throw error;
  }
  const { artifactPath, handshake } = persistedHandshake;

  return phase9SuccessPayload('objective start', {
    objectiveId: activation.objectiveRecord.objectiveId,
    objectiveRecordPath: normalizeSlashes(
      path.relative(repoRoot, activation.objectiveRecordPath)
    ),
    activePointer: ACTIVE_OBJECTIVE_POINTER_RELATIVE_PATH,
    currentWakeLease: activation.activeObjectivePointer.currentWakeLease,
    handshakeArtifactPath: normalizeSlashes(path.relative(repoRoot, artifactPath)),
    handshakeObjective: handshake.objective
  });
}

async function runObjectivePause(repoRoot, parsed) {
  const objectiveId = requiredStringOption(parsed, 'objective', 'objective pause');
  const reason = requiredStringOption(parsed, 'reason', 'objective pause');
  const result = await pauseObjective(repoRoot, objectiveId);
  const { artifactPath, handshake } = await persistCapabilityHandshakeArtifact(repoRoot);
  return phase9SuccessPayload('objective pause', {
    objectiveId,
    reason,
    status: result.objectiveRecord.status,
    activePointer: ACTIVE_OBJECTIVE_POINTER_RELATIVE_PATH,
    activePointerReleased: false,
    handshakeArtifactPath: normalizeSlashes(path.relative(repoRoot, artifactPath)),
    handshakeObjective: handshake.objective
  });
}

async function runObjectiveStop(repoRoot, parsed) {
  const objectiveId = requiredStringOption(parsed, 'objective', 'objective stop');
  const reason = requiredStringOption(parsed, 'reason', 'objective stop');
  const result = await stopObjective(repoRoot, objectiveId);
  const { artifactPath, handshake } = await persistCapabilityHandshakeArtifact(repoRoot);
  return phase9SuccessPayload('objective stop', {
    objectiveId,
    reason,
    status: result.objectiveRecord.status,
    releasedPointer: result.releasedPointerPath,
    handshakeArtifactPath: normalizeSlashes(path.relative(repoRoot, artifactPath)),
    handshakeObjective: handshake.objective
  });
}

function phase9Payload(definition, parsed, code = 'PHASE9_NOT_IMPLEMENTED', extra = {}) {
  return {
    ok: false,
    code,
    command: definition.canonicalCommand,
    phase9: true,
    status: 'stub',
    mutating: definition.mutating,
    requiresPhase9Enabled: definition.mutating,
    phase9Enabled: process.env.VIBE_PHASE9_ENABLED === '1',
    argv: {
      options: parsed.options,
      positionals: parsed.positionals
    },
    ...extra
  };
}

function writeJsonPayload(payload) {
  process.stdout.write(serializeJsonPayload(payload));
}

function serializeJsonPayload(payload) {
  return `${JSON.stringify(payload, null, 2)}\n`;
}

function unsupportedReasoningModePayload(parsed) {
  return {
    ok: false,
    code: 'E_REASONING_MODE_UNSUPPORTED',
    command: 'objective start',
    phase9: true,
    requested: parsed.options['reasoning-mode'],
    supported: ['rule-only'],
    argv: {
      options: parsed.options,
      positionals: parsed.positionals
    }
  };
}

function parsePhase9Invocation(tokens) {
  const [root, maybeAction, ...rest] = tokens;
  if (!PHASE9_ROOTS.includes(root)) {
    return null;
  }

  if (root === 'run-analysis' || root === 'research-loop') {
    const definition = findPhase9Definition(root);
    return {
      kind: 'phase9',
      definition,
      parsed: parseLongOptions(tokens.slice(1))
    };
  }

  if (root === 'capabilities') {
    if (maybeAction === 'doctor') {
      return {
        kind: 'phase9',
        definition: findPhase9Definition(root, 'doctor'),
        parsed: parseLongOptions(rest)
      };
    }

    const parsed = parseLongOptions(tokens.slice(1));
    if (parsed.positionals.length > 0) {
      return {
        kind: 'phase9-error',
        exitCode: 2,
        payload: {
          ok: false,
          code: 'PHASE9_UNKNOWN_SUBCOMMAND',
          command: `capabilities ${parsed.positionals[0]}`,
          phase9: true,
          allowed: ['capabilities --json', 'capabilities doctor']
        }
      };
    }

    if (parsed.options.json === true || parsed.options.json === 'true') {
      return {
        kind: 'phase9',
        definition: findPhase9Definition(root),
        parsed
      };
    }

    return {
      kind: 'phase9-error',
      exitCode: 3,
      payload: {
        ok: false,
        code: 'PHASE9_USAGE',
        command: 'capabilities',
        phase9: true,
        expected: 'capabilities --json or capabilities doctor'
      }
    };
  }

  if (!maybeAction) {
    return {
      kind: 'phase9-error',
      exitCode: 3,
      payload: {
        ok: false,
        code: 'PHASE9_USAGE',
        command: root,
        phase9: true,
        expected: `${root} <subcommand>`
      }
    };
  }

  const definition = findPhase9Definition(root, maybeAction);
  if (!definition) {
    const allowed = PHASE9_STUB_DEFINITIONS
      .filter((candidate) => candidate.root === root)
      .map((candidate) => candidate.canonicalCommand);
    return {
      kind: 'phase9-error',
      exitCode: 2,
      payload: {
        ok: false,
        code: 'PHASE9_UNKNOWN_SUBCOMMAND',
        command: `${root} ${maybeAction}`,
        phase9: true,
        allowed
      }
    };
  }

  const parsed = parseLongOptions(rest);
  if (root === 'objective' && maybeAction === 'start') {
    const requestedReasoningMode = parsed.options['reasoning-mode'];
    if (requestedReasoningMode && requestedReasoningMode !== 'rule-only') {
      return {
        kind: 'phase9-error',
        exitCode: 3,
        payload: unsupportedReasoningModePayload(parsed)
      };
    }
  }

  return {
    kind: 'phase9',
    definition,
    parsed
  };
}

async function invokeEntry(repoRoot, subcommand, entry, reader) {
  const mod = await import(pathToFileURL(path.join(repoRoot, entry.module)).href);
  const helper = mod[entry.export];
  if (typeof helper !== 'function') {
    throw new Error(`${entry.module}#${entry.export} is not a function`);
  }

  if (entry.wrappedByMiddleware) {
    return helper({ projectPath: repoRoot, reader });
  }

  return runWithMiddleware({
    projectPath: repoRoot,
    commandName: `/${subcommand}`,
    scope: entry.scope,
    reader,
    budget: budgetFromEnv(),
    commandFn: async (ctx) => helper(ctx.projectPath, { reader: ctx.reader })
  });
}

async function runInit(repoRoot) {
  const stateRoot = path.join(repoRoot, '.vibe-science-environment');
  const existedBefore = existsSync(stateRoot);
  await mkdir(stateRoot, { recursive: true });
  await mkdir(path.join(stateRoot, 'control'), { recursive: true });
  await mkdir(path.join(stateRoot, 'orchestrator'), { recursive: true });
  await mkdir(path.join(stateRoot, 'operator-validation'), { recursive: true });

  const { kernelRoot, source } = resolveKernelRoot(repoRoot);
  const reader = await resolveKernelReader({ kernelRoot });

  const lines = [];
  lines.push('vre init:');
  lines.push(`  project root: ${repoRoot}`);
  lines.push(`  state root:   .vibe-science-environment/ ${existedBefore ? '(already existed)' : '(created)'}`);
  if (reader.dbAvailable) {
    lines.push(`  kernel:       OK — ${source} at ${kernelRoot}`);
  } else {
    lines.push(`  kernel:       degraded — ${reader.error ?? 'unknown'}`);
    if (source !== 'env') {
      lines.push('  hint:         export VRE_KERNEL_PATH=<path-to-vibe-science> to enable kernel-backed projections');
    }
  }
  lines.push('');
  lines.push('next steps:');
  lines.push('  vre flow-status             # show current operator state');
  lines.push('  vre orchestrator-status     # show queue / lane state');
  lines.push('  vre sync-memory             # refresh markdown mirrors from kernel');
  lines.push('');
  lines.push('agent-only commands (follow the markdown contracts in commands/ via Claude Code):');
  lines.push('  /flow-literature /flow-experiment /flow-results /flow-writing /orchestrator-run');
  lines.push('  /automation-status /export-warning-digest /stale-memory-reminder /weekly-digest');

  process.stdout.write(`${lines.join('\n')}\n`);
  return 0;
}

export async function main(argv = process.argv) {
  const startedAt = Date.now();
  const [, , subcommand, ...rest] = argv;
  if (!subcommand) {
    printUsage();
    return 3;
  }

  if (subcommand === 'init') {
    if (rest.length > 0) {
      process.stderr.write(`vre: init: unexpected arguments: ${rest.join(' ')}\n`);
      return 3;
    }
    const repoRoot = resolveRepoRoot(process.cwd());
    if (!repoRoot) {
      process.stderr.write('vre: current directory is not inside a VRE repository root\n');
      return 3;
    }
    return runInit(repoRoot);
  }

  const phase9Invocation = parsePhase9Invocation([subcommand, ...rest]);
  if (phase9Invocation?.kind === 'phase9-error') {
    writeJsonPayload(phase9Invocation.payload);
    return phase9Invocation.exitCode;
  }
  if (phase9Invocation?.kind === 'phase9') {
    const repoRoot = resolveRepoRoot(process.cwd());
    if (!repoRoot) {
      writeJsonPayload({
        ok: false,
        code: 'NOT_IN_VRE_REPO',
        command: phase9Invocation.definition.canonicalCommand,
        phase9: true
      });
      return 3;
    }

    try {
      if (phase9Invocation.definition.canonicalCommand === 'capabilities --json') {
        const { handshake } = await persistCapabilityHandshakeArtifact(repoRoot);
        process.stdout.write(serializeJsonPayload(handshake));
        return 0;
      }

      if (phase9Invocation.definition.canonicalCommand === 'objective start') {
        const payload = await runObjectiveStart(repoRoot, phase9Invocation.parsed);
        writeJsonPayload(payload);
        return 0;
      }

      if (phase9Invocation.definition.canonicalCommand === 'objective pause') {
        const payload = await runObjectivePause(repoRoot, phase9Invocation.parsed);
        writeJsonPayload(payload);
        return 0;
      }

      if (phase9Invocation.definition.canonicalCommand === 'objective stop') {
        const payload = await runObjectiveStop(repoRoot, phase9Invocation.parsed);
        writeJsonPayload(payload);
        return 0;
      }

      writeJsonPayload(phase9Payload(phase9Invocation.definition, phase9Invocation.parsed));
      return 0;
    } catch (error) {
      if (error instanceof ObjectiveLockHeldError) {
        writeJsonPayload(objectiveLockHeldPayload(error));
        return 1;
      }
      process.stderr.write(`vre: ${phase9Invocation.definition.canonicalCommand}: ${error.message}\n`);
      return 1;
    }
  }

  const entry = DISPATCH_TABLE[subcommand];
  if (!entry) {
    printUnknown(subcommand);
    return 2;
  }

  if (rest.length > 0) {
    process.stderr.write(`vre: ${subcommand}: unexpected arguments: ${rest.join(' ')}\n`);
    return 3;
  }

  const repoRoot = resolveRepoRoot(process.cwd());
  if (!repoRoot) {
    process.stderr.write('vre: current directory is not inside a VRE repository root\n');
    return 3;
  }

  await mkdir(path.join(repoRoot, '.vibe-science-environment'), { recursive: true });
  // Default commands stay quiet on stderr; `vre init` is the dedicated
  // surface for kernel-state announcements. Set VRE_VERBOSE=1 to opt in to
  // per-command kernel state on stderr.
  const announceKernel = process.env.VRE_VERBOSE === '1';
  const reader = await resolveDefaultReader(repoRoot, { announce: announceKernel });

  try {
    const result = await invokeEntry(repoRoot, subcommand, entry, reader);
    const attempt = result?.attempt ?? { status: 'succeeded', attemptId: 'ATT-unknown' };
    if (attempt.status === 'blocked' && attempt.errorCode === 'BUDGET_HARD_STOP') {
      process.stderr.write(`vre: ${subcommand}: ${attempt.summary ?? 'middleware refused'}\n`);
      return 4;
    }

    if (attempt.status !== 'succeeded') {
      process.stderr.write(`vre: ${subcommand}: ${attempt.summary ?? attempt.status}\n`);
      return 1;
    }

    process.stdout.write(`${summaryLine(subcommand, attempt, result, Date.now() - startedAt)}\n`);
    return 0;
  } catch (error) {
    process.stderr.write(`vre: ${subcommand}: ${error.message}\n`);
    return error.code === 'MIDDLEWARE_REFUSED' ? 4 : 1;
  }
}

if (isDirectRun(import.meta)) {
  process.exitCode = await main(process.argv);
}
